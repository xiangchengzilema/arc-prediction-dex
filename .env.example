# Arc Prediction DEX - Environment Variables
# Copy this to .env and fill in your values

# API Configuration
PREDICT_DEX_URL=http://localhost:5003
PREDICT_DEX_PORT=5003
PREDICT_DEX_DB=prediction_dex.db

# Optional API Key for authenticated endpoints
PREDICT_DEX_API_KEY=

# Arc Network (for future on-chain integration)
ARC_RPC_URL=https://rpc.arc.network
ARC_WALLET_ADDRESS=
ARC_PRIVATE_KEY=
